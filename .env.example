# Hot-path agents (Extractor, Memory Manager, Responder)
FAST_MODEL_NAME=meta-llama/llama-3.3-70b-instruct
# Reviewer + Manual Extractor (stronger model, runs rarely)
STRONG_MODEL_NAME=anthropic/claude-sonnet-4-5
MODEL_BASE_URL=https://openrouter.ai/api/v1
MODEL_API_KEY=your_openrouter_api_key_here

# CORS origin for the React dev server
CORS_ORIGIN=http://localhost:5173

# SQLite database path (default: ola.db in current directory)
OLA_DB_PATH=ola.db

# Neo4j (matches docker-compose service defaults)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# MLflow tracing + eval (set MLFLOW_ENABLED=false to disable)
# Use http://localhost:5050 to log against the docker-compose mlflow service
# (matches the "5050:5000" port mapping — host port 5000 is reserved by
# macOS AirPlay Receiver on Macs). The app container overrides this itself
# to http://mlflow:5000 since it talks to mlflow over the docker network.
MLFLOW_ENABLED=true
MLFLOW_TRACKING_URI=http://localhost:5050
MLFLOW_EXPERIMENT=ola-dev
